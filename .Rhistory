# ============================================================
# SERVER
# ============================================================
server <- function(input, output, session) {
observeEvent(input$preset, {
if (input$preset == "aconcagua") {
updateNumericInput(session, "center_lat", value = -32.65306)
updateNumericInput(session, "center_lon", value = -70.01167)
updateNumericInput(session, "radius_km", value = 20)
}
if (input$preset == "santiago") {
updateNumericInput(session, "center_lat", value = -33.45)
updateNumericInput(session, "center_lon", value = -70.50)
updateNumericInput(session, "radius_km", value = 30)
}
if (input$preset == "agua_negra") {
updateNumericInput(session, "center_lat", value = -30.20)
updateNumericInput(session, "center_lon", value = -69.80)
updateNumericInput(session, "radius_km", value = 30)
}
if (input$preset == "bariloche") {
updateNumericInput(session, "center_lat", value = -41.15)
updateNumericInput(session, "center_lon", value = -71.30)
updateNumericInput(session, "radius_km", value = 35)
}
})
result <- eventReactive(input$run, {
withProgress(message = "Calculando sombra topográfica desde GOES-19", value = 0, {
incProgress(0.10, detail = "Descargando DEM online")
dem <- download_dem_local(
center_lon = input$center_lon,
center_lat = input$center_lat,
radius_km = input$radius_km,
z = as.integer(input$z),
cache_dir = "dem_cache"
)
incProgress(0.10, detail = "DEM descargado. Iniciando cálculo")
compute_goes_shadow_local(
dem_wgs84 = dem,
center_lon = input$center_lon,
center_lat = input$center_lat,
lon_sat = input$lon_sat,
max_shadow_km = input$max_shadow_km,
threshold = input$threshold,
max_cells = input$max_cells,
multicore = input$multicore
)
})
})
output$map <- renderLeaflet({
res <- result()
if (is.null(res)) {
return(
leaflet(options = leafletOptions(preferCanvas = TRUE)) |>
addProviderTiles(providers$CartoDB.Positron) |>
setView(lng = input$center_lon, lat = input$center_lat, zoom = 10)
)
}
dem <- res$dem_wgs84
shadow <- res$shadow_wgs84
shade <- res$shade_wgs84
shadow_display <- shadow
shadow_display[shadow_display == 0] <- NA
# Copias livianas SOLO para Leaflet
dem_leaf <- raster_for_leaflet(
dem,
max_cells_display = input$display_max_cells,
method = "mean"
)
shade_leaf <- raster_for_leaflet(
shade,
max_cells_display = input$display_max_cells,
method = "mean"
)
# Para sombra binaria se usa max para NO perder celdas rojas al reducir.
shadow_leaf <- raster_for_leaflet(
shadow_display,
max_cells_display = input$display_max_cells,
method = "max"
)
elev_values <- raster::values(dem_leaf)
elev_values <- elev_values[is.finite(elev_values)]
elev_pal <- leaflet::colorNumeric(
palette = viridisLite::viridis(100),
domain = elev_values,
na.color = "transparent"
)
shadow_pal <- leaflet::colorFactor(
palette = c("red"),
domain = c(1),
na.color = "transparent"
)
shade_pal <- leaflet::colorNumeric(
palette = c("black", "white"),
domain = c(0, 1),
na.color = "transparent"
)
bb <- terra::ext(dem)
max_bytes <- 100 * 1024 * 1024
leaflet(options = leafletOptions(preferCanvas = TRUE)) |>
addProviderTiles(
providers$CartoDB.Positron,
group = "Mapa base"
) |>
addProviderTiles(
providers$Esri.WorldImagery,
group = "Imagen satelital"
) |>
addRasterImage(
dem_leaf,
colors = elev_pal,
opacity = 0.55,
project = TRUE,
group = "DEM",
maxBytes = max_bytes
) |>
addRasterImage(
shade_leaf,
colors = shade_pal,
opacity = 0.35,
project = TRUE,
group = "Factor de luz GOES",
maxBytes = max_bytes
) |>
addRasterImage(
shadow_leaf,
colors = shadow_pal,
opacity = 0.80,
project = TRUE,
group = "Sombra GOES",
maxBytes = max_bytes
) |>
addCircleMarkers(
lng = input$center_lon,
lat = input$center_lat,
radius = 5,
color = "black",
fillColor = "yellow",
fillOpacity = 1,
weight = 2,
label = "Centro AOI"
) |>
addLegend(
position = "bottomright",
colors = c("red", "yellow"),
labels = c(
"Sombra topográfica hacia GOES-19",
"Centro AOI"
),
title = "Resultado",
opacity = 0.85
) |>
addLayersControl(
baseGroups = c("Mapa base", "Imagen satelital"),
overlayGroups = c("DEM", "Factor de luz GOES", "Sombra GOES"),
options = layersControlOptions(collapsed = FALSE)
) |>
fitBounds(
lng1 = bb[1],
lat1 = bb[3],
lng2 = bb[2],
lat2 = bb[4]
)
})
output$static_plot <- renderPlot({
req(result())
dem <- result()$dem_wgs84
shadow <- result()$shadow_wgs84
shadow_display <- shadow
shadow_display[shadow_display == 0] <- NA
terra::plot(
dem,
main = "Chequeo estático: DEM + sombra GOES en rojo",
col = terrain.colors(100)
)
terra::plot(
shadow_display,
add = TRUE,
col = "red",
legend = FALSE
)
})
output$summary_table <- renderTable({
req(result())
result()$summary
})
output$geometry_table <- renderTable({
req(result())
result()$geometry
})
output$download_shadow <- downloadHandler(
filename = function() {
"goes19_shadow_local_wgs84.tif"
},
content = function(file) {
req(result())
terra::writeRaster(
result()$shadow_wgs84,
file,
overwrite = TRUE
)
}
)
output$download_light <- downloadHandler(
filename = function() {
"goes19_light_factor_local_wgs84.tif"
},
content = function(file) {
req(result())
terra::writeRaster(
result()$shade_wgs84,
file,
overwrite = TRUE
)
}
)
}
shinyApp(ui, server)
library(shiny); runApp('inst/shiny/demos/demo_mod_goes_geometry_selected.R')
runApp('inst/shiny/demos/demo_mod_goes_geometry_01.R')
runApp('inst/shiny/demos/demo_mod_goes_geometry_selected.R')
