progbar = FALSE
)
incProgress(0.20, detail = "Convirtiendo sombra a raster")
shadow_binary <- ifelse(shade <= threshold, 1, 0)
shadow_proj <- dem_proj
terra::values(shadow_proj) <- as.vector(t(shadow_binary))
names(shadow_proj) <- "goes_shadow"
shade_proj <- dem_proj
terra::values(shade_proj) <- as.vector(t(shade))
names(shade_proj) <- "goes_light_factor"
incProgress(0.10, detail = "Reproyectando resultado a WGS84")
shadow_wgs84 <- terra::project(
shadow_proj,
"EPSG:4326",
method = "near"
)
shade_wgs84 <- terra::project(
shade_proj,
"EPSG:4326",
method = "bilinear"
)
dem_out_wgs84 <- terra::project(
dem_proj,
"EPSG:4326",
method = "bilinear"
)
shadow_vals <- terra::values(shadow_proj)[, 1]
shadow_count <- sum(shadow_vals == 1, na.rm = TRUE)
valid_count <- sum(!is.na(shadow_vals))
pixel_area_km2 <- prod(terra::res(shadow_proj)) / 1e6
shadow_area_km2 <- shadow_count * pixel_area_km2
list(
shadow_wgs84 = shadow_wgs84,
shade_wgs84 = shade_wgs84,
dem_wgs84 = dem_out_wgs84,
shadow_proj = shadow_proj,
shade_proj = shade_proj,
dem_proj = dem_proj,
geometry = data.frame(
parametro = c(
"Centro latitud",
"Centro longitud",
"Elevación centro DEM m",
"Longitud GOES-19",
"Azimut hacia GOES-19 grados",
"Elevación angular GOES-19 grados",
"Dirección esperada de sombra grados",
"Distancia a GOES-19 km",
"CRS proyectado EPSG",
"Resolución DEM proyectado m",
"Celdas procesadas",
"Max search celdas",
"Max search km",
"Umbral sombra"
),
valor = c(
round(center_lat, 6),
round(center_lon, 6),
round(center_elev, 2),
lon_sat,
round(geo$azimuth_deg, 3),
round(geo$elevation_deg, 3),
round((geo$azimuth_deg + 180) %% 360, 3),
round(geo$distance_km, 2),
epsg,
round(cellsize_m, 2),
n_cells,
maxsearch_cells,
max_shadow_km,
threshold
)
),
summary = data.frame(
clase = c(
"Celdas analizadas",
"Celdas en sombra GOES",
"Área aproximada en sombra km2",
"Porcentaje de celdas en sombra"
),
valor = c(
valid_count,
shadow_count,
round(shadow_area_km2, 4),
round(100 * shadow_count / valid_count, 4)
)
)
)
}
